# =============================================================================
# .env.production.example — Production environment variables for Interview Agent
#
# Copy this to .env and fill in real values:
#   cp .env.production.example .env
#   chmod 600 .env          ← protects API keys from other users
#
# NEVER commit .env to git.
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_BASE_URL=https://interviews.yourcompany.com   # public URL of this server

# Strong random secret — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-string

# ── Database ───────────────────────────────────────────────────────────────────
# Production DB user should NOT be the postgres superuser.
# Create a dedicated user:
#   sudo -u postgres psql
#   CREATE USER interview_agent WITH PASSWORD 'strong-password';
#   CREATE DATABASE interview_agent OWNER interview_agent;
DATABASE_URL=postgresql+asyncpg://interview_agent:strong-password@localhost:5432/interview_agent

# ── Redis (optional — used by rate limiter for multi-process deployments) ──────
REDIS_URL=redis://localhost:6379

# ── AI providers ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...

# ── LiveKit ────────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...

# ── Simli Avatar (optional — voice-only if left empty) ────────────────────────
SIMLI_API_KEY=
SIMLI_FACE_ID=

# ── AWS S3 (for recording storage) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# ── ATS integration ────────────────────────────────────────────────────────────
ATS_BASE_URL=https://ats.yourcompany.com
ATS_SERVICE_TOKEN=

# ── Email (for candidate notifications) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=app-specific-password
EMAIL_FROM=noreply@yourcompany.com
